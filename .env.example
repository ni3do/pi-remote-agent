# === LLM Auth (pick one) ===

# Option 1: Claude subscription (Pro/Max) — run `pi` then `/login` locally, copy values from ~/.pi/agent/auth.json
ANTHROPIC_OAUTH_REFRESH=sk-ant-ort01-...
ANTHROPIC_OAUTH_ACCESS=sk-ant-oat01-...
ANTHROPIC_OAUTH_EXPIRES=1772296027267

# Option 2: API key
# ANTHROPIC_API_KEY=sk-ant-...

# === GitHub (clone + push) ===
GITHUB_TOKEN=github_pat_...

# === Git identity (for commits) ===
GIT_USER_NAME=pi-remote-agent
GIT_USER_EMAIL=pi-remote-agent@noreply

# === Discord Bot (optional) ===
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_CHANNEL_ID=your-channel-id

# === Slack Bot (optional) ===
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
# SLACK_SIGNING_SECRET=your-signing-secret

# === Server ===
PORT=3000
MAX_SESSIONS=8

# === Storage (host paths, or leave unset for Docker named volumes) ===
# WORKSPACE_HOST_PATH=/data/pi-agent/workspace
# SESSIONS_HOST_PATH=/data/pi-agent/sessions
